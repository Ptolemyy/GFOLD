// ===== Defaults (can be overridden by config.txt via RUNPATH) =====
SET KERBIN_R TO 600000.
SET LAT0 TO -0.0972.
SET LON0 TO -74.5577.
SET ALT0 TO 0.

SET THROT1 TO 0.2.        // min throttle fraction
SET THROT2 TO 0.8.        // max throttle fraction
SET THETA_DEG TO 45.      // thrust cone half-angle (deg)
SET YGS_DEG TO 30.        // glide slope angle (deg)
SET RECOMPUTE_TIME TO 5.0. // seconds (for future use)

SET DEG2RAD TO CONSTANT:PI / 180.

// ===== Optional config override =====
// Provide a config.txt in the same directory with lines like:
//   SET LAT0 TO -0.0972.
//   SET LON0 TO -74.5577.
//   SET ALT0 TO 0.
//   SET THROT1 TO 0.2.
//   SET THROT2 TO 0.8.
//   SET THETA_DEG TO 45.
//   SET YGS_DEG TO 30.
SET CONFIG_FILE TO "config.txt".
IF EXISTS(CONFIG_FILE) { RUNPATH(CONFIG_FILE). }.

// Align origin altitude with terrain height at target lat/lon
SET ALT0 TO LATLNG(LAT0, LON0):TERRAINHEIGHT.

// ===== Comm files =====
// Communication contract:
//   - We write state to send.txt (mode0 or mode1 config).
//   - PC solver writes results to receive.txt.
// receive.txt can contain:
//   (A) Request-only: "COMPUTE_FINISH,1" -> ask us to send mode1 config.
//   (B) Full profile: COMPUTE_FINISH + many U lines + DT + END -> update U_LIST.
// Explicitly use Archive volume paths to match PC-side writes.
SET SEND_FILE TO "0:/send.txt".
SET RECV_FILE TO "0:/receive.txt".
SET MODE TO 0.               // 0 = initial solve, 1 = mode1 recompute
SET COMPUTE_FINISH TO 0.     // handshake flag from solver
SET IS_RECOMPUTE TO 1.       // first mode1 state send (one-shot)
SET MODE1_ACTIVE TO 0.       // whether we're consuming a U sequence
SET MODE1_INDEX TO 0.        // current index into U_LIST
SET DT_MODE1 TO 0.           // per-index time step for U_LIST
SET NEXT_UPDATE TO 0.        // next absolute time (ELAPSED_SEC) to advance index
SET U_LIST TO LIST().        // each entry: [u_up,u_north,u_east,t_abs]
SET CR TO CHAR(13).
SET LF TO CHAR(10).
// Fixed loop time step for pacing; elapsed time uses TIME:SECONDS.
// ELAPSED_SEC is the single time axis for U scheduling and recompute.
SET LOOP_DT TO 0.05.
SET LAST_TIME_SEC TO TIME:SECONDS.
SET ELAPSED_SEC TO 0.        // global time since script start
SET LAST_THR_CMD TO 0.       // last throttle command (0..1)
SET LAST_U_UP TO 0.          // last U vector used (ENU)
SET LAST_U_NORTH TO 0.
SET LAST_U_EAST TO 0.
SET ATM_AT TO 1.0.
SET HAS_CUR_U TO 0.          // whether we have a valid U to apply
SET NEXT_RECOMPUTE TO 0.     // next absolute time (ELAPSED_SEC) to request recompute
SET RECOMPUTE_PENDING TO 0.  // recompute requested but not answered yet

// On start, clear send.txt if it exists
IF EXISTS(SEND_FILE) { DELETEPATH(SEND_FILE). }.
// Also clear stale receive.txt to avoid running old/invalid commands
IF EXISTS(RECV_FILE) { DELETEPATH(RECV_FILE). }.

// Make sure receive.txt exists for PC side to use later
IF NOT EXISTS(RECV_FILE) { CREATE(RECV_FILE). }.

// ===== Helper to compute ENU + velocity/state =====
// Build ENU state and vehicle parameters for solver input.
// ENU origin = target lat/lon + terrain height at target.
// Units: meters, m/s, N, s, kg.
FUNCTION CALC_STATE {
  LOCAL CUR_LAT IS SHIP:LATITUDE.
  LOCAL CUR_LON IS SHIP:LONGITUDE.
  LOCAL CUR_ALT IS SHIP:ALTITUDE.

  LOCAL DLON_DEG IS CUR_LON - LON0.
  IF DLON_DEG > 180 { SET DLON_DEG TO DLON_DEG - 360. }.
  IF DLON_DEG < -180 { SET DLON_DEG TO DLON_DEG + 360. }.

  LOCAL DLAT IS (CUR_LAT - LAT0) * DEG2RAD.
  LOCAL DLON IS DLON_DEG * DEG2RAD.

  LOCAL LAT0_RAD IS LAT0 * DEG2RAD.
  LOCAL RE IS KERBIN_R + ALT0.

  LOCAL NORTH_M IS DLAT * RE.
  LOCAL EAST_M  IS DLON * RE * COS(LAT0_RAD).
  LOCAL UP_M    IS CUR_ALT - ALT0.

  LOCAL SPEED IS SHIP:VELOCITY:SURFACE:MAG.
  LOCAL VH IS SHIP:GROUNDSPEED.
  LOCAL VU IS SHIP:VERTICALSPEED.

  LOCAL HDG IS SHIP:HEADING * DEG2RAD.
  LOCAL VN IS VH * COS(HDG).
  LOCAL VE IS VH * SIN(HDG).

  LOCAL ATM_AT IS SHIP:BODY:ATM:ALTITUDEPRESSURE(SHIP:ALTITUDE).
  LOCAL THRUST_MAX IS SHIP:AVAILABLETHRUSTAT(ATM_AT).
  LOCAL ISP_CUR IS 0.
  LIST ENGINES IN ENGS.
  IF ENGS:LENGTH > 0 {
    LOCAL ENG IS ENGS[0].
    FOR E IN ENGS {
      IF E:AVAILABLETHRUST > 0 { SET ENG TO E. BREAK. }.
    }.
    SET ISP_CUR TO ENG:ISPAT(ATM_AT).
  }.
  LOCAL MASS_WET IS SHIP:MASS.

  LOCAL DATA IS LIST().
  DATA:ADD(EAST_M).
  DATA:ADD(NORTH_M).
  DATA:ADD(UP_M).
  DATA:ADD(VE).
  DATA:ADD(VN).
  DATA:ADD(VU).
  DATA:ADD(SPEED).
  DATA:ADD(THRUST_MAX).
  DATA:ADD(ISP_CUR).
  DATA:ADD(MASS_WET).
  RETURN DATA.
}

// Map ENU thrust vector to heading/pitch and throttle.
// Apply acceleration command U (ENU) by mapping to steering and throttle.
// U is acceleration (m/s^2); throttle = |U| * mass / available_thrust.
// Throttle is recomputed every loop using current mass and thrust availability.
FUNCTION APPLY_THRUST {
  PARAMETER U_UP, U_NORTH, U_EAST.
  SET LAST_U_UP TO U_UP.
  SET LAST_U_NORTH TO U_NORTH.
  SET LAST_U_EAST TO U_EAST.
  IF U_UP <> U_UP OR U_NORTH <> U_NORTH OR U_EAST <> U_EAST {
    LOCK THROTTLE TO 0.
    SET LAST_THR_CMD TO 0.
    RETURN.
  }.
  LOCAL A_MAG IS SQRT(U_UP * U_UP + U_NORTH * U_NORTH + U_EAST * U_EAST).
  LOCAL THRUST_AVAIL IS SHIP:AVAILABLETHRUSTAT(SHIP:BODY:ATM:ALTITUDEPRESSURE(SHIP:ALTITUDE)).
  IF A_MAG <= 0 OR THRUST_AVAIL <= 0 {
    LOCK THROTTLE TO 0.
    SET LAST_THR_CMD TO 0.
    RETURN.
  }.

  LOCAL HORIZ IS SQRT(U_NORTH * U_NORTH + U_EAST * U_EAST).
  LOCAL HDG IS 0.
  IF HORIZ <> 0 {
    SET HDG TO ARCTAN2(U_EAST, U_NORTH).
    IF HDG < 0 { SET HDG TO HDG + 360. }.
  }.
  LOCAL PITCH IS ARCTAN2(U_UP, HORIZ).

  LOCK STEERING TO HEADING(HDG, PITCH).

  LOCAL THR_CMD IS A_MAG * SHIP:MASS / THRUST_AVAIL.
  SET THR_CMD TO MIN(THROT2, MAX(THR_CMD, 0)).
  LOCK THROTTLE TO THR_CMD.
  SET LAST_THR_CMD TO THR_CMD.
}

// Send current state to PC for a fresh mode1 solve (recompute).
// This writes a single CSV line to send.txt in the same format as mode0.
FUNCTION SEND_MODE1_STATE {
  SET STATE TO CALC_STATE().
  SET EAST_M TO STATE[0].
  SET NORTH_M TO STATE[1].
  SET UP_M TO STATE[2].
  SET VE TO STATE[3].
  SET VN TO STATE[4].
  SET VU TO STATE[5].
  SET SPEED TO STATE[6].
  SET THRUST_MAX TO STATE[7].
  SET ISP_CUR TO STATE[8].
  SET MASS_WET TO STATE[9].
  SET MODE TO 1.
  SET OUT_LINE TO MODE + "," +
                ROUND(EAST_M,1) + "," +
                ROUND(NORTH_M,1) + "," +
                ROUND(UP_M,1) + "," +
                ROUND(VE,2) + "," +
                ROUND(VN,2) + "," +
                ROUND(VU,2) + "," +
                ROUND(SPEED,2) + "," +
                ROUND(THRUST_MAX,1) + "," +
                ROUND(ISP_CUR,1) + "," +
                ROUND(MASS_WET,1) + "," +
                ROUND(THROT1,2) + "," +
                ROUND(THROT2,2) + "," +
                ROUND(THETA_DEG,1) + "," +
                ROUND(YGS_DEG,1).

  IF NOT EXISTS(SEND_FILE) { CREATE(SEND_FILE). }.
  SET f TO OPEN(SEND_FILE).
  f:CLEAR().
  f:WRITELN(OUT_LINE).
  PRINT "SEND MODE1: " + OUT_LINE.
}

// ===== Single-shot mode0 compute and write =====
// Initial request to solver. PC will respond with COMPUTE_FINISH,1 to
// request a mode1 state line, or later a full U profile.
LOCAL STATE IS CALC_STATE().
SET EAST_M TO STATE[0].
SET NORTH_M TO STATE[1].
SET UP_M TO STATE[2].
SET VE TO STATE[3].
SET VN TO STATE[4].
SET VU TO STATE[5].
SET SPEED TO STATE[6].
SET THRUST_MAX TO STATE[7].
SET ISP_CUR TO STATE[8].
SET MASS_WET TO STATE[9].

// Pack and write mode0
SET OUT_LINE TO MODE + "," +
               ROUND(EAST_M,1) + "," +
               ROUND(NORTH_M,1) + "," +
               ROUND(UP_M,1) + "," +
               ROUND(VE,2) + "," +
               ROUND(VN,2) + "," +
               ROUND(VU,2) + "," +
               ROUND(SPEED,2) + "," +
               ROUND(THRUST_MAX,1) + "," +
               ROUND(ISP_CUR,1) + "," +
               ROUND(MASS_WET,1) + "," +
               ROUND(THROT1,2) + "," +
               ROUND(THROT2,2) + "," +
               ROUND(THETA_DEG,1) + "," +
               ROUND(YGS_DEG,1).

IF NOT EXISTS(SEND_FILE) { CREATE(SEND_FILE). }.
SET f TO OPEN(SEND_FILE).
f:CLEAR().
f:WRITELN(OUT_LINE).
PRINT "SEND MODE0: " + OUT_LINE.

// ===== Main loop: read solver outputs, trigger recompute, and apply U =====
UNTIL FALSE {
  SET NOW_SEC TO TIME:SECONDS.
  // Single time axis:
  // - ELAPSED_SEC: global time since script start (used for U timestamps and recompute).
  IF NOW_SEC < LAST_TIME_SEC {
    SET ELAPSED_SEC TO ELAPSED_SEC + (NOW_SEC + 60 - LAST_TIME_SEC).
  } ELSE {
    SET ELAPSED_SEC TO ELAPSED_SEC + (NOW_SEC - LAST_TIME_SEC).
  }.
  SET LAST_TIME_SEC TO NOW_SEC.

  // Read solver output from receive.txt (if any).
  // We parse lines into NEW_U_LIST + NEW_DT_MODE1 and only swap in if valid.
  IF EXISTS(RECV_FILE) {
    SET RECV_LINE TO OPEN(RECV_FILE):READALL:STRING.
    IF RECV_LINE <> "" {
      SET COMPUTE_FINISH TO 0.
      SET HAS_FINISH TO 0.
      SET SEEN_DT TO 0.
      SET U_COUNT TO 0.
      SET NEW_DT_MODE1 TO 0.
      SET NEW_U_LIST TO LIST().
      SET RECV_LINE TO RECV_LINE:REPLACE(CR, "").
      SET RECV_LINES TO RECV_LINE:SPLIT(LF).
      // Parse COMPUTE_FINISH, DT, and U lines into NEW_U_LIST.
      // If only COMPUTE_FINISH is present, NEW_VALID stays 0 and U_LIST is kept.
      FOR L IN RECV_LINES {
        IF L <> "" {
          SET PARTS TO L:SPLIT(",").
          IF PARTS:LENGTH >= 2 {
            IF PARTS[0] = "COMPUTE_FINISH" AND PARTS[1]:STARTSWITH("1") {
              SET HAS_FINISH TO 1.
            } ELSE IF PARTS[0] = "U" AND PARTS:LENGTH >= 4 {
              SET U_UP TO PARTS[1]:TONUMBER.
              SET U_NORTH TO PARTS[2]:TONUMBER.
              SET U_EAST TO PARTS[3]:TONUMBER.
              // Time will be assigned after DT is known.
              NEW_U_LIST:ADD(LIST(U_UP, U_NORTH, U_EAST, 0)).
              SET U_COUNT TO U_COUNT + 1.
            } ELSE IF PARTS[0] = "DT" {
              SET NEW_DT_MODE1 TO PARTS[1]:TONUMBER.
              SET SEEN_DT TO 1.
            }.
          }.
        }.
      }.
        IF HAS_FINISH = 1 {
          // New profile received: only swap in if it is valid (has U + DT).
          SET NEW_VALID TO 0.
          IF U_COUNT > 0 AND SEEN_DT = 1 AND NEW_DT_MODE1 > 0 { SET NEW_VALID TO 1. }.
          IF NEW_VALID = 1 {
            SET U_LIST TO NEW_U_LIST.
            SET DT_MODE1 TO NEW_DT_MODE1.
          }.
          // Any COMPUTE_FINISH clears the recompute pending flag.
          SET RECOMPUTE_PENDING TO 0.
          IF RECOMPUTE_TIME > 0 { SET NEXT_RECOMPUTE TO ELAPSED_SEC + RECOMPUTE_TIME. }.

        SET HAS_U TO 0.
        IF U_LIST:LENGTH > 0 { SET HAS_U TO 1. }.
        IF HAS_U = 1 AND DT_MODE1 > 0 {
          SET COMPUTE_FINISH TO 1.
        } ELSE IF HAS_U = 0 AND DT_MODE1 <= 0 {
          SET COMPUTE_FINISH TO 1.
        }.
        IF COMPUTE_FINISH = 1 {
          IF NEW_VALID = 1 {
            SET rf TO OPEN(RECV_FILE).
            rf:CLEAR().
          }.
          PRINT "COMPUTE_FINISH".
          PRINT U_LIST:LENGTH.
          IF NEW_VALID = 1 AND U_LIST:LENGTH > 0 {
            // Start consuming new U list immediately.
            SET MODE1_ACTIVE TO 1.
            SET MODE1_INDEX TO 0.
            // Build absolute time for each U sample on the global time axis.
            SET I TO 0.
            UNTIL I >= U_LIST:LENGTH {
              SET U_ENTRY TO U_LIST[I].
              SET U_ENTRY[3] TO ELAPSED_SEC + (I * DT_MODE1).
              SET U_LIST[I] TO U_ENTRY.
              SET I TO I + 1.
            }.
            SET NEXT_UPDATE TO U_LIST[0][3].
            SET U0 TO U_LIST[0].
            APPLY_THRUST(U0[0], U0[1], U0[2]).
            SET HAS_CUR_U TO 1.
          }.
          IF IS_RECOMPUTE = 1 {
            // First time: immediately request mode1 solve.
            SEND_MODE1_STATE().
            SET IS_RECOMPUTE TO 0.
            SET RECOMPUTE_PENDING TO 1.
          }.
        }.
      }.
    }.
  }.
  // Periodic recompute trigger: request a new solve while continuing to use old U.
  IF MODE1_ACTIVE = 1 AND RECOMPUTE_TIME > 0 AND RECOMPUTE_PENDING = 0 AND ELAPSED_SEC >= NEXT_RECOMPUTE {
    PRINT "RECOMPUTE_TRIGGER t=" + ROUND(ELAPSED_SEC,2).
    SEND_MODE1_STATE().
    SET RECOMPUTE_PENDING TO 1.
  }.
  // Advance U index by absolute timestamps in U_LIST.
  IF MODE1_ACTIVE = 1 {
    IF U_LIST:LENGTH = 0 {
      SET MODE1_ACTIVE TO 0.
      LOCK THROTTLE TO 0.
      SET LAST_THR_CMD TO 0.
      SET HAS_CUR_U TO 0.
    } ELSE {
      // Advance index based on absolute timestamps stored in U_LIST.
      UNTIL (MODE1_INDEX + 1) >= U_LIST:LENGTH OR ELAPSED_SEC < U_LIST[MODE1_INDEX + 1][3] {
        SET MODE1_INDEX TO MODE1_INDEX + 1.
      }.
      IF MODE1_INDEX >= U_LIST:LENGTH {
        // U list exhausted: stop thrust.
        SET MODE1_ACTIVE TO 0.
        LOCK THROTTLE TO 0.
        SET LAST_THR_CMD TO 0.
        SET HAS_CUR_U TO 0.
        PRINT "MODE1_DONE".
      } ELSE {
        SET U_CUR TO U_LIST[MODE1_INDEX].
        APPLY_THRUST(U_CUR[0], U_CUR[1], U_CUR[2]).
        SET HAS_CUR_U TO 1.
      }.
    }.
  }.
  // Re-apply current U every loop so throttle tracks changing mass.
  IF MODE1_ACTIVE = 1 AND HAS_CUR_U = 1 {
    APPLY_THRUST(LAST_U_UP, LAST_U_NORTH, LAST_U_EAST).
  }.
  // Telemetry output for debugging (horizontal error, thrust, mass).
  SET ATM_AT TO SHIP:BODY:ATM:ALTITUDEPRESSURE(SHIP:ALTITUDE).
  SET STATE TO CALC_STATE().
  SET EAST_M TO STATE[0].
  SET NORTH_M TO STATE[1].
  SET UP_M TO STATE[2].
  SET ERR_M TO SQRT(EAST_M * EAST_M + NORTH_M * NORTH_M).
  PRINT "t=" + ROUND(ELAPSED_SEC,2) +
        " err=" + ROUND(ERR_M,1) +
        " thrust=" + ROUND(LAST_THR_CMD * SHIP:AVAILABLETHRUSTAT(ATM_AT),1) +
        " mass=" + ROUND(SHIP:MASS,3).
  WAIT LOOP_DT.
}
PRINT "PROGRAM_END".
